# ========== TELEGRAM ==========
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=@your_channel_username_or_-100xxxxxxxxxx

# ========== TELETHON (чтение TG-каналов) ==========
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_PHONE=+7your_phone_number

# ========== VK API ==========
VK_ACCESS_TOKEN=your_vk_token
VK_API_VERSION=5.131

# ========== SUPERJOB (опционально) ==========
SUPERJOB_SECRET=your_superjob_secret

# ========== ФИЛЬТРЫ ==========
SALARY_MIN=30000
SCHEDULE_TYPE=remote

# ========== ЛИМИТЫ ==========
MAX_PER_SESSION=10
DELAY_BETWEEN_POSTS=5
HOURS_LOOKBACK=24

# ========== ИСТОЧНИКИ (1=включён, 0=выключен) ==========
SOURCE_HH=1
SOURCE_TRUDVSEM=1
SOURCE_SUPERJOB=0
SOURCE_VK=1
SOURCE_TG=1
SOURCE_AVITO=0
SOURCE_HABR=1
